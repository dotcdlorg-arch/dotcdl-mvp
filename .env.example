# ══════════════════════════════════════════════════════
# CDL English Pro — Environment Variables Template
# Copy to .env.local and fill all values
# NEVER commit .env.local to GitHub
# ══════════════════════════════════════════════════════

# Supabase — supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Clerk — clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/practice
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/practice

# OpenAI — platform.openai.com → API Keys
# Required for Whisper STT, GPT scoring, conversation AI, pronunciation
OPENAI_API_KEY=sk-xxx

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:3000
